{
  "expo": {
    "name": "ResQ",
    "slug": "resq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "resq",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.resq.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ResQ needs your location to dispatch nearby service providers.",
        "NSLocationAlwaysUsageDescription": "ResQ needs your location to track service providers in real-time."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.resq.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ResQ to use your location for emergency dispatch."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
